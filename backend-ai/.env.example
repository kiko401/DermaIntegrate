# ==========================================
# 智能推理域 环境变量配置模板
# 使用说明：复制本文件为 .env，并根据实际运行环境修改配置
# 命令：cp .env.example .env
# ==========================================

# --- 数据库配置 ---
# [本地开发] 映射到宿主机 3307 端口
DATABASE_URL=mysql+aiomysql://root:root@localhost:3307/derma_ai
# [Docker部署] 请注释掉上面一行，启用下面这行（使用容器名 mysql 和内部端口 3306）
# DATABASE_URL=mysql+aiomysql://root:root@mysql:3306/derma_ai

# --- 日志级别 ---
LOG_LEVEL=INFO

# --- 视觉语言模型 (DeepSeek-VL2) 配置 ---
# 注意：请替换为你真实的 API Key，切勿将真实 Key 提交到 Git 仓库！
VLM_API_KEY=sk-your-deepseek-api-key
VLM_BASE_URL=https://api.deepseek.com
VLM_MODEL=deepseek-vl2

# --- 整合/病历提取大模型配置 ---
# 用于多模态信息融合、结构化报告生成与自由病历文本解析
# 注意：请替换为你真实的 API Key，切勿将真实 Key 提交到 Git 仓库！
INTEGRATION_API_KEY=sk-your-deepseek-api-key
INTEGRATION_BASE_URL=https://api.deepseek.com
# 根据最新公告，原 deepseek-chat 已替换为 deepseek-v4-flash (非思考模式，保证JSON稳定输出)
INTEGRATION_MODEL=deepseek-v4-flash

# --- 降级开关配置 ---
# 设为 true 时，将拦截真实 VLM 调用并返回预设 Mock 数据，便于前端联调或无网络环境测试
USE_MOCK_VLM=true
# 设为 true 时，将拦截真实整合 Agent 调用并返回预设 Mock 结构化报告，便于前端联调
USE_MOCK_INTEGRATION=true

# --- RAG 向量数据库配置 ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=derma_knowledge

# --- Docker 环境标识 ---
# [本地开发] 设为 false，代码将连接 localhost 的 Qdrant
# [Docker部署] 必须设为 true，代码将连接 Qdrant 容器名 (覆盖上方 QDRANT_HOST)
DOCKER_ENV=false

# --- HuggingFace 镜像源 (国内云服务器部署必填) ---
# 解决国内服务器无法下载 bge-small-zh-v1.5 模型的问题
# 本地开发如网络正常可忽略，云端 Docker 部署必须配置
HF_ENDPOINT=https://hf-mirror.com