# ==========================================
# DermaIntegrate AI 环境变量配置模板
# ==========================================
# 使用说明：
# 1. 复制本文件为 .env：cp .env.example .env
# 2. 填入您的真实 API Key
# 3. 根据运行环境（本地/Docker）调整数据库连接

# --- 数据库配置 ---
# 注意：若使用 Docker Compose 启动，数据库地址应使用容器名 'mysql'；
# 若在本地单独运行 MySQL，请使用 'localhost'。
DATABASE_URL=mysql+aiomysql://root:root@localhost:3307/derma_ai

# --- 日志配置 ---
LOG_LEVEL=INFO

# --- 视觉语言模型 (VLM) 配置 ---
# 用于图像形态学特征提取
VLM_API_KEY=sk-your-vlm-api-key-placeholder
VLM_BASE_URL=https://api.minimaxi.com/v1
VLM_MODEL=MiniMax-M3

# --- 整合/病历提取大模型配置 ---
# 用于多模态信息融合、结构化报告生成与病历文本解析
INTEGRATION_API_KEY=sk-your-integration-api-key-placeholder
INTEGRATION_BASE_URL=https://api.deepseek.com
INTEGRATION_MODEL=deepseek-v4-flash

# --- 降级开关配置 ---
# USE_MOCK_VLM: 设为 true 时，VLM 将返回预设 Mock 数据，避免产生 API 费用或因审核导致失败。
USE_MOCK_VLM=true

# USE_MOCK_INTEGRATION: 设为 true 时，整合 Agent 将返回 Mock 报告，便于快速调试管线。
USE_MOCK_INTEGRATION=true

# --- Docker 环境标识 ---
# true: 云端或 Docker 容器内运行 (连接 Qdrant 容器名)
# false: 本地开发环境运行 (连接 localhost Qdrant)
DOCKER_ENV=false

# --- HuggingFace 镜像源 (国内服务器必填) ---
# 解决国内网络无法下载 bge-small-zh-v1.5 模型的问题
HF_ENDPOINT=https://hf-mirror.com