# ==========================================================
# Python 虚拟环境
# ==========================================================
.venv/
venv/
env/

# ==========================================================
# Python 编译缓存与字节码
# ==========================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================================
# 环境配置与敏感信息
# ==========================================================
# 本地开发配置文件，生产环境通过 Docker Compose 环境变量或云端密钥注入
.env
.env.local

# ==========================================================
# 运行时生成的数据文件
# ==========================================================
# 本地或 Docker Volume 挂载的运行时目录，包含上传的原图与生成的热力图
uploads/
static/images/
static/heatmaps/

# 运行日志文件
logs/
*.log

# ==========================================================
# IDE 与编辑器配置
# ==========================================================
.idea/
.vscode/
*.swp
*.swo

# ==========================================================
# 操作系统生成文件
# ==========================================================
.DS_Store
Thumbs.db

# ==========================================================
# Git 自身
# ==========================================================
.git/
.gitignore