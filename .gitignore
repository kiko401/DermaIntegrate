# =============== Python 编译与虚拟环境 ===============
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
env/
*.egg-info/

# =============== 环境配置（包含密码密钥，严禁提交） ===============
.env

# =============== 模型权重文件（体积过大，严禁入库） ===============
# 训练产出的权重或导出的 ONNX 模型，体积通常在 20MB-200MB
# 云端部署时通过 SCP 单独上传，绝不走 Git 仓库
*.onnx
*.pth
*.pt

# =============== 运行时生成的文件 ===============
# 用户上传的原始文件和 AI 生成的图片绝对不能进 Git 仓库
backend-ai/uploads/
backend-ai/static/

# =============== 阶段性测试与临时脚本 ===============
backend-ai/test_*.py
backend-ai/test_data/
backend-ai/diagnose_color.py
backend-ai/test_sse.html

# =============== IDE 与编辑器配置 ===============
.idea/
.vscode/
*.swp
*.swo

# =============== 操作系统生成文件 ===============
.DS_Store
Thumbs.db