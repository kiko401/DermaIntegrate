# AI 推理域路由地址
AI_BASE_URL=http://124.222.0.186/ai

# Node/Express 服务端口
PORT=3000

# 数据库连接（四库共用同一 host/user/password，各自独立 DB）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root_password

# 应用主库
APP_DB_NAME=derma_app

# 外部源库（正式多库架构）
HIS_DB_NAME=derma_his
LIS_DB_NAME=derma_lis
PACS_DB_NAME=derma_pacs

# 旧单库名（原型兼容，迁移完成后可移除）
DB_NAME=derma_integrate

# JWT 鉴权
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=24h

# 演示医生账号（npm run seed 时使用）
DEMO_DOCTOR_NAME=演示医生
DEMO_DOCTOR_USERNAME=doctor
DEMO_DOCTOR_PASSWORD=demo123